OGS_API_KEY_15K=
OGS_API_KEY_10K=
OGS_API_KEY_5K=
OGS_BOT_PLAYER_ID_5K=
OGS_API_KEY_1D=

# Optional: OAuth bearer token for REST challenge reconciliation.
# Without this, challenge handling still works through the OGS websocket,
# but missed websocket challenge notifications cannot be recovered by polling.
OGS_REST_ACCESS_TOKEN=

KATAGO_BIN=katago
KATAGO_MODEL=/path/to/kata1-b28c512nbt-s12704148736-d5790336910.bin.gz
KATAGO_HUMAN_MODEL=/path/to/b18c384nbt-humanv0.bin.gz
KATAGO_CONFIG=config/katago-human-rank-5k.cfg
KATAGO_ENDING_CONFIG=config/katago-ending.cfg

# Optional: extra args passed to every gtp2ogs instance before "--".
GTP2OGS_EXTRA_ARGS=

# Optional: comma-separated KataGo overrides passed as "-override-config".
# Example: logDir=gtp_logs,delayMoveScale=4.0
KATAGO_OVERRIDE_CONFIG=
